# AEGIS X - Backend Environment Configurations Example
PORT=8000
HOST=0.0.0.0

# Google Gemini API Configurations
# Obtain key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
# Default is SQLite: sqlite:///./aegis_x.db
# To connect to production Supabase PostgreSQL:
# DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./aegis_x.db
