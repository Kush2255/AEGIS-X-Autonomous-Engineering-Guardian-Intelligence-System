# PRAHARI AI – Frontend Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard → Project → Settings → Environment Variables for production

# Backend API URL
# Development: leave blank (defaults to http://localhost:8000)
# Production: Set to your deployed backend URL (Railway / Render / other)
VITE_API_URL=https://your-backend-url.railway.app
